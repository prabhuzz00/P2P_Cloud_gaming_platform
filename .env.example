# ===========================================
# P2P Cloud Gaming Platform - Docker Compose Environment
# Copy this file to .env and update the values
# ===========================================

# Database
DB_USER=p2p_gaming
DB_PASSWORD=your-secure-database-password
DB_PORT=5432

# Backend
JWT_SECRET=generate-a-secure-random-string-here
JWT_REFRESH_SECRET=generate-another-secure-random-string-here
BACKEND_PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,https://your-admin-domain.com

# Admin Panel
ADMIN_PORT=3001
REACT_APP_API_URL=http://localhost:3000

# Google Play (for token purchases)
GOOGLE_PLAY_PACKAGE_NAME=com.p2pgaming.client

# ===========================================
# WebRTC NAT Traversal Configuration
# ===========================================
# This platform uses MANUAL PORT FORWARDING as the primary NAT traversal method.
# STUN servers (Google) are included by default for public IP discovery.
#
# TURN server is OPTIONAL - only needed if:
#   - Host PC is behind a symmetric NAT (rare for home routers)
#   - Port forwarding is not possible on the host's router
#   - Corporate/restrictive firewalls block direct UDP connections
#
# For most home setups: Forward UDP ports 47984-48010 on the host's router
# and TURN is NOT required.
#
# Uncomment below ONLY if you need TURN relay:
# TURN_SERVER_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=username
# TURN_CREDENTIAL=credential

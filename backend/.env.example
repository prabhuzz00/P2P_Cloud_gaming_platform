# ===========================================
# P2P Cloud Gaming Backend - Environment Config
# ===========================================

# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=******localhost:5432/p2p_gaming
DATABASE_SSL=false

# Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Google Play (for token purchases)
GOOGLE_PLAY_PACKAGE_NAME=com.p2pgaming.client
# GOOGLE_PLAY_SERVICE_ACCOUNT_KEY=/path/to/service-account.json

# WebRTC TURN Server (optional - required for NAT traversal)
# TURN_SERVER_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=username
# TURN_CREDENTIAL=credential

# Redis (optional - for session caching)
# REDIS_URL=redis://localhost:6379

# Legacy (deprecated - use ALLOWED_ORIGINS instead)
ADMIN_PANEL_ORIGIN=http://localhost:5173
